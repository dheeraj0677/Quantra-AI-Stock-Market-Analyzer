# ────────────────────────────────────────────────────────────
# Quantra Backend — Environment Variables
# Copy to .env and fill in real values
# ────────────────────────────────────────────────────────────

# ── Database ──
DATABASE_URL=postgresql+asyncpg://quantra:secret@localhost:5432/quantra
DATABASE_URL_SYNC=postgresql://quantra:secret@localhost:5432/quantra

# ── Redis ──
REDIS_URL=redis://localhost:6379/0

# ── Kafka ──
KAFKA_BROKER=localhost:9092

# ── Auth / JWT ──
JWT_SECRET_KEY=change-me-to-a-64-char-random-string
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# ── Market Data APIs ──
ALPHA_VANTAGE_API_KEY=your-alpha-vantage-key
TWELVE_DATA_API_KEY=your-twelve-data-key

# ── ML / Object Storage (MinIO) ──
MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET_MODELS=quantra-models
MINIO_SECURE=false

# ── Notifications ──
FCM_SERVER_KEY=your-firebase-cloud-messaging-key
WEBHOOK_SECRET=your-webhook-signing-secret

# ── Scraper Settings ──
NEWS_SCRAPE_INTERVAL_MINUTES=15
SCRAPER_RATE_LIMIT_SECONDS=2

# ── Market Hours (IST) ──
MARKET_HOURS_START=09:15
MARKET_HOURS_END=15:30
MARKET_TIMEZONE=Asia/Kolkata

# ── Application ──
APP_ENV=development
DEBUG=true
LOG_LEVEL=INFO
CORS_ORIGINS=http://localhost:3000,http://localhost:3001,http://localhost:8081
